{
  "name": "jins-us-dj36-sales-openapi",
  "version": "1.0.0",
  "description": "Sales BFF API Server.",
  "main": "server.ts",
  "type": "commonjs",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "scripts": {
    "dev": "npx ts-node-dev -r tsconfig-paths/register ./app/server.ts --debug",
    "lint": "npx prettier --write 'app/**/*.ts' && eslint --fix 'app/**/{*.js,*.ts}'",
    "generate": "npm run generate:client && npm run generate:related-client",
    "generate:client": "npx openapi-typescript ./app/openapi/root.yaml -o ./app/src/interfaces/root.ts",
    "generate:related-client": "bash ./app/openapi/clients/generate_related_clients.sh",
    "test": "npm run test:run && npm run test:update_status_badge",
    "test:run": "npx jest",
    "test:update_status_badge": "chmod +x ./app/__tests__/get_function_coverage_badge.sh && ./app/__tests__/get_function_coverage_badge.sh",
    "doc": "npm run doc:typedoc && npm run doc:openapi",
    "doc:typedoc": "npx typedoc --out ./docs/typedoc ./app -exclude ./app/__test__",
    "doc:openapi": "npx @redocly/cli build-docs ./app/openapi/root.yaml --output=./docs/openapi/index.html"
  },
  "dependencies": {
    "@date-fns/tz": "^1.2.0",
    "@types/node-fetch": "^2.6.11",
    "cors": "^2.8.5",
    "dd-trace": "^5.56.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-openapi": "^12.1.3",
    "express-winston": "^4.2.0",
    "i18n": "^0.15.1",
    "inversify": "^6.0.2",
    "node-fetch": "^2.7.0",
    "openapi-typescript-fetch": "^2.0.0",
    "path": "^0.12.7",
    "path-to-regexp": "0.1.12",
    "reflect-metadata": "^0.1.13",
    "undici": "^6.19.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.7.0",
    "@redocly/cli": "^1.16.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/i18n": "^0.13.12",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "openapi-typescript": "^6.7.5",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.25.13",
    "typescript": "^5.4.5",
    "typesync": "^0.14.3"
  }
}
